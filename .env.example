# ==========================================
# 🚀 Auto Price App 환경 변수 설정 파일 템플릿
# ==========================================
# 이 파일을 복사해서 `.env` 라는 이름으로 만들고,
# 아래의 빈칸 '...' 에 발급받은 실제 API 키들을 채워넣으세요.

# ------------------------------------------
# 1. Supabase (데이터베이스) 설정
# ------------------------------------------
# Supabase 웹사이트 (Project Settings -> API)에서 확인 가능합니다.
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# 아래는 백엔드 워커(터미널)에서만 사용하는 관리자 키입니다 (절대 노출 금지)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# ------------------------------------------
# 2. BrightData (크롤링 프록시 우회) 설정
# ------------------------------------------
# BrightData 웹사이트에서 Web Unlocker 또는 Proxy 발급 후 기입
BRIGHTDATA_PROXY_URL="http://brd.superproxy.io:22225"
BRIGHTDATA_PROXY_USERNAME="brd-customer-xxxx-zone-xxxx"
BRIGHTDATA_PROXY_PASSWORD="YOUR_PROXY_PASSWORD"

# ------------------------------------------
# 3. Market API (판매처 통신) 설정
# ------------------------------------------
# 향후 쿠팡 Wing API 나 네이버 커머스 API 등 발급 시 사용
COUPANG_VENDOR_ID="..."
COUPANG_ACCESS_KEY="..."
COUPANG_SECRET_KEY="..."
